---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Asembleas Abertas do Ensino Público",
  description = "Unha rede aberta e descentralizada para organizar o ensino público galego.",
} = Astro.props;
---

<!doctype html>
<html lang="gl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#252321" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#contido" class="sr-only focus:not-sr-only focus:fixed focus:z-[9999] focus:bg-paper focus:p-4">
      Ir ao contido
    </a>
    <header class="border-b border-ink/20 bg-paper">
      <div class="mx-auto flex max-w-[1500px] items-center justify-between px-4 py-4 md:px-8">
        <a href="/" class="focus-ring flex items-center gap-3 no-underline" aria-label="AAEP, portada">
          <span class="grid h-9 w-9 place-items-center bg-ink text-sm font-black text-paper">AA</span>
          <span class="max-w-44 text-[11px] font-extrabold uppercase leading-[1.05] tracking-[.1em]">
            Asembleas Abertas<br />do Ensino Público
          </span>
        </a>
        <nav aria-label="Navegación principal" class="hidden items-center gap-7 text-xs font-bold uppercase tracking-wider lg:flex">
          <a class="focus-ring decoration-red decoration-2 underline-offset-4 hover:underline" href="/#mapa">Mapa</a>
          <a class="focus-ring decoration-red decoration-2 underline-offset-4 hover:underline" href="/a-rede">A rede</a>
          <a class="focus-ring decoration-red decoration-2 underline-offset-4 hover:underline" href="/actualidade">Actualidade</a>
          <a class="focus-ring decoration-red decoration-2 underline-offset-4 hover:underline" href="/materiais">Materiais</a>
          <a class="focus-ring decoration-red decoration-2 underline-offset-4 hover:underline" href="/martes-en-loita">Martes en loita</a>
          <a class="focus-ring bg-ink px-4 py-3 text-paper hover:bg-red" href="/#participa">Activa o teu centro</a>
        </nav>
        <button id="menu-button" class="focus-ring border border-ink px-3 py-2 text-xs font-bold uppercase lg:hidden" aria-expanded="false">
          Menú
        </button>
      </div>
      <nav id="mobile-menu" class="hidden border-t border-ink/20 px-4 py-4 text-sm font-bold uppercase lg:hidden">
        <div class="grid gap-4">
          <a href="/#mapa">Mapa</a>
          <a href="/a-rede">A rede</a>
          <a href="/actualidade">Actualidade</a>
          <a href="/materiais">Materiais</a>
          <a href="/martes-en-loita">Martes en loita</a>
          <a href="/#participa">Activa o teu centro</a>
        </div>
      </nav>
    </header>
    <main id="contido"><slot /></main>
    <footer class="bg-ink text-paper">
      <div class="mx-auto grid max-w-[1500px] gap-12 px-4 py-14 md:grid-cols-12 md:px-8">
        <div class="md:col-span-6">
          <p class="display text-5xl sm:text-7xl">O público<br />organízase.</p>
        </div>
        <div class="grid gap-8 text-sm md:col-span-3">
          <a href="/#mapa">Mapa da rede</a>
          <a href="/a-rede">A rede</a>
          <a href="/actualidade">Actualidade</a>
          <a href="/materiais">Materiais</a>
          <a href="/martes-en-loita">Martes en loita</a>
        </div>
        <div class="grid content-start gap-8 text-sm md:col-span-3">
          <a href="mailto:info@asembleasensino.gal">info@asembleasensino.gal</a>
          <a href="https://instagram.com/asembleasensino" class="inline-flex items-center gap-3" aria-label="Instagram de Asembleas Ensino, @asembleasensino">
            <svg aria-hidden="true" class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="18" height="18" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.4" cy="6.7" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
            <span>@asembleasensino</span>
          </a>
          <p class="text-paper/60">Galicia · 2026</p>
        </div>
      </div>
    </footer>
    <script>
      const button = document.querySelector<HTMLButtonElement>("#menu-button");
      const menu = document.querySelector<HTMLElement>("#mobile-menu");
      button?.addEventListener("click", () => {
        const open = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!open));
        menu?.classList.toggle("hidden", open);
      });
    </script>
  </body>
</html>
