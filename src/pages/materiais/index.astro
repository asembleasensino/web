---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getMateriais, materialUrl } from "../../lib/content";
import { site } from "../../config/site";

const materiais = await getMateriais();
const [destacado, ...resto] = materiais;
---
<BaseLayout title={`Materiais · ${site.shortName}`}>
  <header class="mx-auto grid max-w-[1500px] gap-8 px-4 pb-12 pt-16 md:px-8 md:pb-20 md:pt-24 lg:grid-cols-12">
    <div class="lg:col-span-8">
      <h1 class="display text-[clamp(5rem,13vw,11rem)]">Materiais</h1>
    </div>
    <p class="max-w-sm self-end text-lg leading-relaxed text-ink/65 lg:col-span-4">Documentos abertos, reutilizables e preparados para o traballo cotián nos centros.</p>
  </header>
  <section class="mx-auto max-w-[1500px] px-4 pb-28 md:px-8">
    <div class="mb-12 grid gap-5 border-y border-ink/25 py-5 sm:grid-cols-[1fr_220px]">
      <input id="material-search" class="focus-ring border-0 bg-transparent px-0 py-2 text-sm" type="search" placeholder="Buscar no arquivo de materiais" />
      <select id="material-type" class="focus-ring border-0 bg-transparent px-0 py-2 text-sm text-ink/65">
        <option value="">Todos os tipos</option>
        {[...new Set(materiais.map((material) => material.data.type))].sort().map((type) => <option value={type}>{type}</option>)}
      </select>
    </div>
    {destacado ? (
      <div class="grid gap-12 lg:grid-cols-12">
        <a
          href={materialUrl(destacado)}
          data-material
          data-type={destacado.data.type}
          data-search={`${destacado.data.title} ${destacado.data.summary} ${destacado.data.tags.join(" ")}`.toLocaleLowerCase("gl")}
          class="group border-t-4 border-green pt-6 no-underline lg:col-span-5"
        >
          <span class="eyebrow text-green">{destacado.data.type}{destacado.data.featured ? " · Destacado" : ""}</span>
          <h2 class="mt-12 max-w-lg text-4xl font-extrabold leading-[1.02] tracking-[-.035em] group-hover:text-green sm:text-5xl">{destacado.data.title}</h2>
          <p class="mt-6 max-w-md text-sm leading-relaxed text-ink/60">{destacado.data.summary}</p>
          <div class="mt-12 flex items-center justify-between border-t border-ink/25 pt-4 text-xs text-ink/50"><span>{destacado.data.tags.join(" · ")}</span><span class="text-xl text-ink">→</span></div>
        </a>
        <div class="lg:col-span-7 lg:pt-14">
          {resto.map((material, index) => (
            <a
              href={materialUrl(material)}
              data-material
              data-type={material.data.type}
              data-search={`${material.data.title} ${material.data.summary} ${material.data.tags.join(" ")}`.toLocaleLowerCase("gl")}
              class="group grid grid-cols-[minmax(0,1fr)_auto] gap-5 border-t border-ink/25 py-6 no-underline last:border-b"
            >
              <div>
                <span class="eyebrow text-green">{material.data.type}</span>
                <h2 class:list={["mt-4 font-extrabold leading-tight group-hover:text-green", index === 0 ? "text-3xl" : "text-2xl"]}>{material.data.title}</h2>
                <p class="mt-3 text-sm text-ink/55">{material.data.summary}</p>
              </div>
              <span class="self-end text-xl">→</span>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="border-y border-ink py-16">
        <p class="max-w-xl text-xl font-bold">Os materiais publicaranse aquí desde o panel editorial e almacenaranse en Google Drive.</p>
      </div>
    )}
  </section>
  <script>
    const search = document.querySelector<HTMLInputElement>("#material-search");
    const type = document.querySelector<HTMLSelectElement>("#material-type");
    const cards = [...document.querySelectorAll<HTMLElement>("[data-material]")];
    const normalize = (value: string) => value.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLocaleLowerCase("gl");
    const filter = () => {
      const query = normalize(search?.value.trim() || "");
      const selectedType = type?.value || "";
      for (const card of cards) {
        const haystack = normalize(card.dataset.search || "");
        const visible = (!query || haystack.includes(query)) && (!selectedType || card.dataset.type === selectedType);
        card.classList.toggle("hidden", !visible);
      }
    };
    search?.addEventListener("input", filter);
    type?.addEventListener("change", filter);
  </script>
</BaseLayout>
