---
import BaseLayout from "../../layouts/BaseLayout.astro";
const materiais = [
  ["Guía", "Como poñer en marcha unha asemblea de centro", "PDF · 1,2 MB"],
  ["Modelo", "Acta básica de asemblea", "ODT · 84 KB"],
  ["Cartaz", "Martes en loita — editable", "PDF · 4,6 MB"],
  ["Documento legal", "Dereito de reunión nos centros educativos", "PDF · 620 KB"],
  ["Presentación", "Que son as Asembleas Abertas?", "ODP · 2,1 MB"],
  ["Recurso", "Kit de comunicación para redes", "ZIP · 18 MB"],
];
---
<BaseLayout title="Materiais · AAEP">
  <header class="mx-auto grid max-w-[1500px] gap-8 px-4 pb-12 pt-16 md:grid-cols-12 md:px-8 md:pb-20 md:pt-24">
    <div class="md:col-span-8">
      <h1 class="display text-[clamp(5rem,13vw,11rem)]">Materiais</h1>
    </div>
    <p class="max-w-sm self-end text-lg leading-relaxed text-ink/65 md:col-span-4">Documentos abertos, reutilizables e preparados para o traballo cotián nos centros.</p>
  </header>
  <section class="mx-auto max-w-[1500px] px-4 pb-28 md:px-8">
    <div class="mb-12 grid gap-5 border-y border-ink/25 py-5 sm:grid-cols-[1fr_220px]">
      <input class="focus-ring border-0 bg-transparent px-0 py-2 text-sm" type="search" placeholder="Buscar no arquivo de materiais" />
      <select class="focus-ring border-0 bg-transparent px-0 py-2 text-sm text-ink/65"><option>Todos os tipos</option><option>Guías</option><option>Modelos</option><option>Cartaces</option></select>
    </div>
    <div class="grid gap-12 lg:grid-cols-12">
      <article class="border-t-4 border-green pt-6 lg:col-span-5">
        <span class="eyebrow text-green">{materiais[0][0]} destacada</span>
        <h2 class="mt-12 max-w-lg text-4xl font-extrabold leading-[1.02] tracking-[-.035em] sm:text-5xl">{materiais[0][1]}</h2>
        <p class="mt-6 max-w-md text-sm leading-relaxed text-ink/60">Unha guía breve para convocar, organizar e dar continuidade a unha asemblea no teu centro.</p>
        <div class="mt-12 flex items-center justify-between border-t border-ink/25 pt-4 text-xs text-ink/50"><span>{materiais[0][2]}</span><span class="text-xl text-ink">↓</span></div>
      </article>
      <div class="lg:col-span-7 lg:pt-14">
        {materiais.slice(1).map((material, index) => (
          <article class="group grid grid-cols-[minmax(0,1fr)_auto] gap-5 border-t border-ink/25 py-6 last:border-b">
            <div>
              <span class="eyebrow text-green">{material[0]}</span>
              <h2 class:list={["mt-4 font-extrabold leading-tight group-hover:text-green", index === 0 ? "text-3xl" : "text-2xl"]}>{material[1]}</h2>
              <p class="mt-3 text-xs text-ink/45">{material[2]}</p>
            </div>
            <span class="self-end text-xl">↓</span>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
