---
import BaseLayout from "../layouts/BaseLayout.astro";
import AssemblyMap from "../components/AssemblyMap.astro";
import ActivationForm from "../components/ActivationForm.astro";
import { actualidadeUrl, formatDate, getActualidade } from "../lib/content";
import home from "../data/home.json";

const actualidade = await getActualidade();
const novas = [
  ...actualidade.filter((entry) => entry.data.featured),
  ...actualidade.filter((entry) => !entry.data.featured),
].slice(0, 3);
const agora = new Date();
const convocatorias = actualidade
  .filter((entry) => entry.data.type === "Convocatoria" && entry.data.eventDate && entry.data.eventDate >= agora)
  .sort((a, b) => (a.data.eventDate?.getTime() || 0) - (b.data.eventDate?.getTime() || 0))
  .slice(0, 3);
---

<BaseLayout>
  <section class="overflow-hidden">
    <div class="mx-auto grid min-h-[54vh] max-w-[1500px] px-4 py-10 md:min-h-[58vh] md:px-8 md:py-14">
      <div class="grid content-between gap-12 lg:grid-cols-12">
        <div class="min-w-0 lg:col-span-9">
          <h1 class="display type-home-hero">
            {home.heroTitle}<br /><span class="inline-block whitespace-nowrap text-red">{home.heroHighlight}</span>
          </h1>
        </div>
        <div class="min-w-0 flex max-w-sm flex-col justify-end pb-3 lg:col-span-3">
          <p class="text-lg leading-relaxed">
            {home.heroIntroduction}
          </p>
          <a href="#mapa" class="focus-ring mt-7 flex items-center justify-between border-t border-ink pt-4 text-xs font-black uppercase tracking-wider no-underline">
            Explora a rede <span class="text-xl">↓</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="py-10 md:py-16">
    <AssemblyMap />
  </div>

  {novas.length > 0 && <section data-reveal class="mx-auto max-w-[1500px] px-4 py-20 md:px-8 md:py-32">
    <div class="grid gap-5 lg:grid-cols-12">
      <figure class="group overflow-hidden lg:col-span-7">
        <img
          src="/images/manifestacion/asembleas-abertas-mobilizacion-1.webp"
          alt="Manifestación de Asembleas Abertas do Ensino Público"
          class="documentary-image aspect-[4/3] h-full w-full object-cover"
          loading="lazy"
          width="1600"
          height="1470"
        />
      </figure>
      <figure class="group overflow-hidden lg:col-span-5 lg:mt-24">
        <img
          src="/images/manifestacion/asembleas-abertas-mobilizacion-2.webp"
          alt="Cabeceira dunha mobilización en defensa do ensino público"
          class="documentary-image aspect-[4/3] h-full w-full object-cover"
          loading="lazy"
          width="1600"
          height="1200"
        />
      </figure>
      <div class="mt-10 lg:col-span-4 lg:col-start-9 lg:mt-14">
        <h2 class="type-editorial-section font-extrabold leading-[1.02] tracking-[-.04em]">{home.organizationTitle}</h2>
        <p class="mt-8 text-base leading-relaxed text-ink/65">{home.organizationText}</p>
        <a href="/a-rede/" class="mt-9 inline-block border-b border-red pb-1 text-xs font-black uppercase tracking-wider">{home.organizationLinkLabel}</a>
      </div>
    </div>
    <div data-reveal class="mt-16 ml-auto grid max-w-5xl gap-8 border-t border-ink/25 pt-8 md:grid-cols-3">
      {home.levels.map((level) => <div><h3 class="text-xl font-bold">{level.title}</h3><p class="mt-3 text-sm leading-relaxed text-ink/60">{level.text}</p></div>)}
    </div>
  </section>

  <section class="mx-auto max-w-[1500px] px-4 py-20 md:px-8 md:py-32">
    <div class="mb-12 flex items-end justify-between border-b border-ink pb-5">
      <div>
        <h2 class="display type-display-section">Actualidade</h2>
      </div>
      <a href="/actualidade" class="hidden text-xs font-black uppercase tracking-wider underline decoration-red decoration-2 underline-offset-4 sm:block">Ver todas →</a>
    </div>
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-0">
      <a href={actualidadeUrl(novas[0])} class="group border-b border-ink/25 pb-10 no-underline lg:col-span-7 lg:border-r lg:border-b-0 lg:pb-0 lg:pr-12">
        <div class="flex items-center gap-4">
          <span class="eyebrow text-red">{novas[0].data.type}</span>
          <span class="text-[10px] font-bold text-ink/40">{formatDate(novas[0].data.date)}</span>
        </div>
        <h3 class="type-feature-title mt-10 max-w-3xl font-extrabold leading-[.98] tracking-[-.04em] group-hover:text-red">
          {novas[0].data.title}
        </h3>
        <p class="mt-8 max-w-xl text-base leading-relaxed text-ink/65">{novas[0].data.summary}</p>
        <span class="mt-10 block text-xl" aria-hidden="true">→</span>
      </a>
      <div class="lg:col-span-5 lg:pl-12 lg:pt-16">
        {novas.slice(1).map((nova, index) => (
          <a href={actualidadeUrl(nova)} class:list={["group block border-ink/25 py-7 no-underline", index === 0 ? "border-b pt-0" : "pb-0"]}>
            <div class="flex items-center justify-between">
              <span class="eyebrow text-red">{nova.data.type}</span>
              <span class="text-[10px] font-bold text-ink/40">{formatDate(nova.data.date)}</span>
            </div>
            <h3 class="type-card-title mt-6 max-w-md font-extrabold leading-tight group-hover:text-red">{nova.data.title}</h3>
            <p class="mt-4 max-w-md text-sm leading-relaxed text-ink/60">{nova.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>}

  <section data-reveal class="bg-green text-paper">
    <div class="mx-auto grid max-w-[1500px] gap-14 px-4 py-20 md:px-8 md:py-32 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2 class="display type-display-section-lg whitespace-pre-line">{home.networkTitle}</h2>
        <p class="mt-8 max-w-md text-base leading-relaxed text-paper/70">{home.networkText}</p>
      </div>
      <ol class="grid border-t border-paper/30 lg:col-span-7 lg:col-start-6 lg:mt-10">
        {home.participationSteps.map((step, index) => (
          <li class="grid grid-cols-[4.5rem_minmax(0,1fr)] gap-5 border-b border-paper/30 py-8 sm:grid-cols-[6rem_minmax(0,1fr)] sm:py-10">
            <span class="display type-step-number text-paper/40">{String(index + 1).padStart(2, "0")}</span>
            <div class="pt-1"><h3 class="type-card-title font-extrabold">{step.title}</h3><p class="mt-3 max-w-xl text-base leading-relaxed text-paper/75">{step.text}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {convocatorias.length > 0 && <section class="mx-auto max-w-[1500px] px-4 py-20 md:px-8 md:py-32">
    <div class="grid gap-16 lg:grid-cols-12 lg:gap-24">
      <div class="min-w-0 lg:col-span-5">
        <h2 class="display type-display-section">Próximas<br />convocatorias</h2>
      </div>
      <div class="min-w-0 lg:col-span-7 lg:pt-28">
        {convocatorias.map((evento, index) => (
          <a href={actualidadeUrl(evento)} class:list={["min-w-0 grid grid-cols-[5.5rem_minmax(0,1fr)_auto] items-center gap-4 border-t border-ink/25 no-underline last:border-b", index === 0 ? "py-9" : "py-6"]}>
            <div>
              <strong class="display block text-4xl">{evento.data.eventDate?.getDate()}</strong>
              <span class="eyebrow text-red">{evento.data.eventDate?.toLocaleDateString("gl-ES", { month: "short", timeZone: "Europe/Madrid" })}</span>
            </div>
            <div>
              <h3 class:list={["font-extrabold", index === 0 ? "text-2xl" : "text-lg"]}>{evento.data.title}</h3>
              <p class="mt-1 text-sm text-ink/55">{evento.data.eventLocation || formatDate(evento.data.eventDate!)}</p>
            </div>
            <span aria-hidden="true" class="text-2xl">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  <ActivationForm />
</BaseLayout>
