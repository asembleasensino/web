---
import BaseLayout from "../layouts/BaseLayout.astro";
import rede from "../data/rede.json";
import { site } from "../config/site";
---

<BaseLayout title={`A rede · ${site.shortName}`}>
  <header class="mx-auto grid max-w-[1500px] gap-10 px-4 pb-16 pt-16 md:grid-cols-12 md:px-8 md:pb-24 md:pt-28">
    <h1 class="display text-[clamp(4.5rem,11vw,10rem)] md:col-span-8">A rede</h1>
    <p class="max-w-md self-end text-lg leading-relaxed text-ink/70 md:col-span-4">{rede.titulo}</p>
  </header>

  <section class="mx-auto grid max-w-[1500px] gap-12 border-t border-ink px-4 py-16 md:grid-cols-12 md:px-8 md:py-24">
    <p class="max-w-3xl text-2xl font-bold leading-snug md:col-span-7 md:text-4xl">{rede.introducion}</p>
    <div class="space-y-5 text-sm leading-relaxed text-ink/65 md:col-span-4 md:col-start-9">
      <p>A rede non substitúe as asembleas: conéctaas. As decisións nacen nos centros e coordínanse nas comarcas e na asemblea xeral.</p>
      <a class="inline-block border-b border-red pb-1 font-bold text-ink" href="/#mapa">Consulta o mapa da rede →</a>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="mx-auto grid max-w-[1500px] gap-14 px-4 py-20 md:grid-cols-12 md:px-8 md:py-28">
      <div class="md:col-span-5">
        <h2 class="display text-6xl sm:text-8xl">Grupos e comunidade</h2>
        <p class="mt-8 max-w-md text-sm leading-relaxed text-paper/65">{rede.textoWhatsapp}</p>
        {rede.comunidadeWhatsapp && (
          <a class="mt-8 inline-block bg-paper px-5 py-4 text-xs font-black uppercase tracking-wider text-ink" href={rede.comunidadeWhatsapp}>Entrar na comunidade</a>
        )}
      </div>
      <div class="md:col-span-7 md:pt-16">
        {rede.grupos.map((grupo) => (
          <article class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-5 border-t border-paper/25 py-5 last:border-b">
            <h3 class="text-xl font-bold">{grupo.nome}</h3>
            <div class="flex gap-5 text-xs font-bold uppercase tracking-wider text-paper/65">
              {grupo.arquivo && <a href={grupo.arquivo}>Arquivo</a>}
              {grupo.whatsapp ? <a class="text-paper" href={grupo.whatsapp}>WhatsApp ↗</a> : <span>Ligazón pendente</span>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-[1500px] gap-12 px-4 py-20 md:grid-cols-12 md:px-8 md:py-28">
    <h2 class="display text-6xl md:col-span-5 sm:text-8xl">Coidar os espazos</h2>
    <ol class="border-t border-ink md:col-span-7 md:mt-16">
      {rede.normas.map((norma, index) => (
        <li class="grid grid-cols-[3rem_1fr] gap-5 border-b border-ink/25 py-6">
          <span class="text-xs text-ink/35">0{index + 1}</span>
          <p class="text-lg font-bold leading-snug">{norma}</p>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
