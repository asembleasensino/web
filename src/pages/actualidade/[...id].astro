---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { actualidadeUrl, formatDate } from "../../lib/content";
import { site } from "../../config/site";

export async function getStaticPaths() {
  const entries = await getCollection("actualidade", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { id: entry.id.replace(/\.(md|mdx)$/i, "") },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"actualidade">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = new URL(actualidadeUrl(entry), Astro.site);
---

<BaseLayout title={`${entry.data.title} · ${site.shortName}`} description={entry.data.summary} canonical={canonical}>
  <article>
    <header class="mx-auto grid max-w-[1500px] gap-8 px-4 pb-14 pt-16 md:grid-cols-12 md:px-8 md:pb-20 md:pt-24">
      <div class="md:col-span-3">
        <span class="eyebrow text-red">{entry.data.type}</span>
        <p class="mt-4 text-sm text-ink/50">{formatDate(entry.data.date)}</p>
      </div>
      <div class="md:col-span-9">
        <h1 class="max-w-5xl text-[clamp(3rem,7vw,7rem)] font-extrabold leading-[.94] tracking-[-.05em]">{entry.data.title}</h1>
        <p class="mt-8 max-w-3xl text-xl leading-relaxed text-ink/65">{entry.data.summary}</p>
        {entry.data.eventDate && (
          <div class="mt-8 border-l-4 border-red pl-5">
            <p class="font-extrabold">{formatDate(entry.data.eventDate, { hour: "2-digit", minute: "2-digit" })}</p>
            {entry.data.eventLocation && <p class="mt-1 text-sm text-ink/60">{entry.data.eventLocation}</p>}
          </div>
        )}
      </div>
    </header>
    {entry.data.image && (
      <figure class="mx-auto max-w-[1500px] px-4 md:px-8">
        <img src={entry.data.image} alt="" class="max-h-[760px] w-full object-cover" />
      </figure>
    )}
    <div class="mx-auto grid max-w-[1500px] gap-10 px-4 py-16 md:grid-cols-12 md:px-8 md:py-24">
      <a href="/actualidade/" class="text-xs font-black uppercase tracking-wider underline decoration-red decoration-2 underline-offset-4 md:col-span-3">← Actualidade</a>
      <div class="content-body md:col-span-8">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
