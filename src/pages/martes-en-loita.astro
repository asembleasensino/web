---
import BaseLayout from "../layouts/BaseLayout.astro";
import { centros as allCentros } from "../data/centros";
import { site } from "../config/site";
import MartesGallery from "../components/MartesGallery.astro";
const centros = allCentros.map(({ codigo, nome, concello, comarca }) => ({ codigo, nome, concello, comarca }));
const centrosJson = JSON.stringify(centros).replace(/</g, "\\u003c");
---

<BaseLayout title={`Martes en loita · ${site.shortName}`}>
  <header class="mx-auto grid max-w-[1500px] gap-10 px-4 pb-16 pt-16 md:grid-cols-12 md:px-8 md:pb-24 md:pt-28">
    <h1 aria-label="Martes en loita" class="display text-[clamp(4rem,11vw,10rem)] md:col-span-8">
      <span aria-hidden="true">Martes<br />en
      <span class="relative inline-block">
        loit<span class="relative inline-block">o<span class="absolute inset-0 rotate-[7deg] text-red" aria-hidden="true">A</span></span>
      </span></span>
    </h1>
    <p class="max-w-md self-end text-lg leading-relaxed text-ink/70 md:col-span-4">Envía a imaxe da acción do teu centro. O ficheiro entrará na estrutura compartida que alimenta o pipeline de publicacións.</p>
  </header>

  <section class="bg-green text-paper">
    <div class="mx-auto grid max-w-[1500px] gap-14 px-4 py-20 md:grid-cols-12 md:px-8 md:py-28">
      <div class="md:col-span-4">
        <h2 class="display text-5xl sm:text-7xl">Un arquivo colectivo</h2>
        <p class="mt-8 max-w-sm text-sm leading-relaxed text-paper/70">Sube unha fotografía por centro e data. Non é preciso preparar a imaxe: o sistema existente encárgase do resto.</p>
        <a
          href="https://afouta.com/es/camisetas/622-5004-ensino-en-loitao.html#/11-color-negro/102-talla-xs/130-composicion-algodon_organica_vegana"
          target="_blank"
          rel="noopener noreferrer"
          class="focus-ring mt-10 block max-w-sm border-t border-paper/35 pt-5 no-underline"
        >
          <span class="eyebrow text-paper/55">A camiseta da mobilización</span>
          <strong class="mt-3 block text-xl leading-tight">Aínda non tedes a vosa camiseta? Facede o pedido na web de Afouta ↗</strong>
        </a>
      </div>
      <form id="martes-form" data-contact-email={site.email} action="/api/martes-en-loita" method="post" enctype="multipart/form-data" class="grid gap-5 bg-paper p-5 text-ink sm:p-8 md:col-span-7 md:col-start-6">
        <div>
          <label class="mb-2 block text-xs font-bold" for="martes-centro">Centro</label>
          <div class="relative">
            <input id="martes-centro" autocomplete="off" role="combobox" aria-autocomplete="list" aria-controls="martes-centros-list" aria-expanded="false" required placeholder="Nome do centro ou concello" class="focus-ring w-full border border-ink/30 bg-paper px-4 py-3" />
            <div id="martes-centros-list" role="listbox" class="absolute z-20 mt-1 hidden max-h-64 w-full overflow-y-auto border border-ink/30 bg-paper"></div>
          </div>
          <input id="martes-centro-nome" name="centro" type="hidden" />
          <input id="martes-centro-codigo" name="centroCodigo" type="hidden" />
          <input id="martes-concello" name="concello" type="hidden" />
          <input id="martes-comarca" name="comarca" type="hidden" />
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-xs font-bold" for="martes-data">Data</label>
            <input id="martes-data" name="data" type="date" required class="focus-ring w-full border border-ink/30 bg-paper px-4 py-3" />
            <p class="mt-2 text-xs text-ink/50">Só se admiten martes.</p>
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold" for="martes-foto">Fotografía</label>
            <input id="martes-foto" name="foto" type="file" accept="image/jpeg,image/png,image/webp" required class="focus-ring w-full border border-ink/30 bg-paper px-4 py-3 text-sm" />
          </div>
        </div>
        <label class="flex items-start gap-3 text-xs leading-relaxed">
          <input class="mt-1 accent-green" type="checkbox" name="autorizacion" value="confirmed" required />
          <span>Confirmo que a imaxe pode ser entregada á AAEP para o seu arquivo e posible publicación.</span>
        </label>
        <button class="focus-ring justify-self-start bg-ink px-6 py-4 text-xs font-black uppercase tracking-wider text-paper" type="submit">Enviar fotografía →</button>
        <p id="martes-status" class="hidden text-sm font-bold" role="status"></p>
      </form>
    </div>
  </section>
  <MartesGallery />
  <script is:inline id="martes-centros-data" type="application/json" set:html={centrosJson}></script>
  <script>
    const form = document.querySelector<HTMLFormElement>("#martes-form");
    const centreSearch = document.querySelector<HTMLInputElement>("#martes-centro");
    const centreName = document.querySelector<HTMLInputElement>("#martes-centro-nome");
    const centreCode = document.querySelector<HTMLInputElement>("#martes-centro-codigo");
    const concello = document.querySelector<HTMLInputElement>("#martes-concello");
    const comarca = document.querySelector<HTMLInputElement>("#martes-comarca");
    const dateInput = document.querySelector<HTMLInputElement>("#martes-data");
    const results = document.querySelector<HTMLElement>("#martes-centros-list");
    const status = document.querySelector<HTMLElement>("#martes-status");
    const centres = JSON.parse(document.querySelector<HTMLScriptElement>("#martes-centros-data")?.textContent || "[]") as Array<{
      codigo: string; nome: string; concello: string; comarca: string;
    }>;
    const normalize = (value: string) => value.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLocaleLowerCase("gl");
    const selectCentre = (centre: typeof centres[number]) => {
      if (centreSearch) centreSearch.value = `${centre.nome} — ${centre.concello}`;
      if (centreName) centreName.value = centre.nome;
      if (centreCode) centreCode.value = centre.codigo;
      if (concello) concello.value = centre.concello;
      if (comarca) comarca.value = centre.comarca;
      results?.classList.add("hidden");
      centreSearch?.setAttribute("aria-expanded", "false");
    };
    centreSearch?.addEventListener("input", () => {
      if (centreName) centreName.value = "";
      if (centreCode) centreCode.value = "";
      const query = normalize(centreSearch.value.trim());
      const matches = query.length < 2 ? [] : centres
        .filter((centre) => normalize(`${centre.nome} ${centre.concello} ${centre.codigo}`).includes(query))
        .slice(0, 8);
      if (!results) return;
      results.replaceChildren(...matches.map((centre) => {
        const button = document.createElement("button");
        button.type = "button";
        button.role = "option";
        button.className = "block w-full border-b border-ink/15 px-4 py-3 text-left text-sm last:border-0 hover:bg-ink hover:text-paper";
        button.innerHTML = `<strong>${centre.nome}</strong><span class="mt-1 block text-xs opacity-60">${centre.concello}</span>`;
        button.addEventListener("click", () => selectCentre(centre));
        return button;
      }));
      results.classList.toggle("hidden", matches.length === 0);
      centreSearch.setAttribute("aria-expanded", String(matches.length > 0));
    });
    const validateTuesday = () => {
      if (!dateInput?.value) return true;
      const isTuesday = new Date(`${dateInput.value}T12:00:00Z`).getUTCDay() === 2;
      dateInput.setCustomValidity(isTuesday ? "" : "Selecciona un martes.");
      return isTuesday;
    };
    dateInput?.addEventListener("change", () => {
      validateTuesday();
      dateInput.reportValidity();
    });
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!centreCode?.value) {
        centreSearch?.setCustomValidity("Selecciona un centro da lista.");
        centreSearch?.reportValidity();
        return;
      }
      centreSearch?.setCustomValidity("");
      if (!validateTuesday()) {
        dateInput?.reportValidity();
        return;
      }
      const button = form.querySelector<HTMLButtonElement>("button");
      if (button) button.disabled = true;
      try {
        const response = await fetch(form.action, { method: "POST", body: new FormData(form) });
        if (!response.ok) throw new Error();
        const result = await response.json() as { storedIn?: string[]; warning?: string };
        form.reset();
        if (status) {
          status.textContent = result.storedIn?.includes("drive")
            ? "Imaxe recibida e gardada no arquivo colectivo."
            : "Imaxe recibida na copia de seguridade. O equipo revisará o envío a Drive.";
          status.classList.remove("hidden");
        }
      } catch {
        if (status) {
          status.textContent = `Non foi posible enviar a imaxe. Escríbenos a ${form.dataset.contactEmail}.`;
          status.classList.remove("hidden");
        }
      } finally {
        if (button) button.disabled = false;
      }
    });
  </script>
</BaseLayout>
